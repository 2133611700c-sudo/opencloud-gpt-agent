{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencloud-gpt-agent/schemas/openclaw-result-schema-v1.json",
  "title": "OpenClaw Result Schema v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "task_id",
    "run_id",
    "status",
    "started_at",
    "finished_at",
    "summary",
    "actions_taken",
    "files_changed",
    "commits",
    "pull_request",
    "tests",
    "artifacts",
    "warnings",
    "errors",
    "next_step"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["success", "failed", "blocked", "partial"]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "actions_taken": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 500
      }
    },
    "files_changed": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 500
      }
    },
    "commits": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "pull_request": {
      "type": ["object", "null"]
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 2000
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 12000
      }
    },
    "next_step": {
      "type": ["string", "null"],
      "maxLength": 2000
    }
  }
}
