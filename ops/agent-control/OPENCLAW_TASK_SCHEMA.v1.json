{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencloud-gpt-agent/schemas/openclaw-task-schema-v1.json",
  "title": "OpenClaw Task Schema v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "requested_by", "goal", "params", "safety", "expected_status"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "type": {
      "type": "string",
      "enum": [
        "heartbeat",
        "virtual_browser_audit",
        "synthetic_fail",
        "worker_heartbeat",
        "job_lead_collect",
        "job_lead_audit",
        "outreach_draft",
        "outreach_send_approved",
        "codex_delegate",
        "repo_audit",
        "repo_patch",
        "supabase_check",
        "synthetic_lead_check",
        "regression_check"
      ]
    },
    "requested_by": {
      "type": "string",
      "minLength": 2,
      "maxLength": 80
    },
    "created_by": {
      "type": "string",
      "minLength": 2,
      "maxLength": 80
    },
    "goal": {
      "type": "string",
      "minLength": 10,
      "maxLength": 2000
    },
    "objective": {
      "type": "string",
      "minLength": 10,
      "maxLength": 2000
    },
    "instructions": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20000
    },
    "repository": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "base_branch": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "priority": {
      "type": "string",
      "enum": ["P0", "P1", "P2", "P3"]
    },
    "created_at": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "locked", "running", "completed", "failed", "blocked", "degraded"]
    },
    "params": {
      "type": "object"
    },
    "allowed_paths": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 300
      }
    },
    "forbidden_paths": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 300
      }
    },
    "allowed_actions": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      }
    },
    "forbidden_actions": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      }
    },
    "requires_pr": {
      "type": "boolean"
    },
    "allow_direct_push": {
      "type": "boolean"
    },
    "allow_merge": {
      "type": "boolean"
    },
    "timeout_minutes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 60
    },
    "acceptance_criteria": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    },
    "context": {
      "type": "object"
    },
    "metadata": {
      "type": "object"
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["customer_action", "public_posting", "paid_ads_change", "destructive_action"],
      "properties": {
        "production_code_change": {
          "type": "boolean"
        },
        "customer_action": {
          "type": "boolean",
          "const": false
        },
        "secrets_required": {
          "type": "boolean"
        },
        "public_posting": {
          "type": "boolean",
          "const": false
        },
        "paid_ads_change": {
          "type": "boolean",
          "const": false
        },
        "destructive_action": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "expected_status": {
      "type": "string",
      "enum": ["PASS", "FAIL", "BLOCKED", "DEGRADED"]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "repo_patch"
          }
        }
      },
      "then": {
        "required": ["allowed_paths", "allowed_actions", "requires_pr", "allow_direct_push", "allow_merge", "acceptance_criteria"],
        "properties": {
          "allow_direct_push": {
            "const": false
          },
          "allow_merge": {
            "const": false
          },
          "params": {
            "type": "object",
            "additionalProperties": false,
            "required": ["target_file", "append_line"],
            "properties": {
              "target_file": {
                "type": "string",
                "minLength": 1,
                "maxLength": 300
              },
              "append_line": {
                "type": "string",
                "minLength": 1,
                "maxLength": 500
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "heartbeat"
          }
        }
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "additionalProperties": false,
            "maxProperties": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "synthetic_fail"
          }
        }
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "additionalProperties": false,
            "maxProperties": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "virtual_browser_audit"
          }
        }
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "additionalProperties": true,
            "required": ["target_origin", "routes", "max_attempts"],
            "properties": {
              "target_origin": {
                "type": "string",
                "pattern": "^https://[^/?#]+$"
              },
              "routes": {
                "type": "array",
                "minItems": 1,
                "maxItems": 20,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 160,
                  "pattern": "^/(?!/)(?!.*\\.\\.)[^\\s]*$"
                }
              },
              "max_attempts": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              }
            }
          }
        }
      }
    }
  ]
}
